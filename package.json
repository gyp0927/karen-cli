{
  "name": "@jhonzs/karen-cli",
  "version": "0.1.0",
  "description": "A general-purpose coding assistant CLI inspired by Claude Code",
  "type": "module",
  "main": "dist/bin/karen.js",
  "bin": {
    "karen": "dist/bin/karen.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/karen.js",
    "test": "tsx --test tests/**/*.test.ts",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "test:e2e": "tsx --test tests/e2e/**/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "ai",
    "coding-assistant",
    "chatgpt",
    "claude",
    "deepseek"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gyp0927/karen-cli.git"
  },
  "bugs": {
    "url": "https://github.com/gyp0927/karen-cli/issues"
  },
  "homepage": "https://github.com/gyp0927/karen-cli#readme",
  "engines": {
    "node": ">=20.0.0"
  }
}
